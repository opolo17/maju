{
  "name": "maju",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:landing": "npm run dev -w @maju/landing",
    "dev:web": "npm run dev -w @maju/web",
    "build:landing": "npm run build -w @maju/landing",
    "build:web": "npm run build -w @maju/web",
    "build": "npm run build:landing && npm run build:web",
